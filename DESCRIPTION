Package: TopTreeSegR
Type: Package
Title: Topological Tree Segmentation using Discrete Morse Theory
Version: 1.0.0
Authors@R: 
    person(
        given = "Gergo",
        family = "Dioszegi",
        email = "dijogergo@gmail.com",
        role = c("aut", "cre", "cph"),
        comment = c(ORCID = "0009-0003-3454-9093")
